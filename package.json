{
  "name": "kaamnow",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start --dev-client",
    "start:tunnel": "expo start --dev-client --tunnel",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "build:dev:android": "npx -y eas-cli build --profile development --platform android --non-interactive",
    "build:dev:ios": "npx -y eas-cli build --profile development --platform ios --non-interactive",
    "build:sim": "npx -y eas-cli build --profile simulator --platform ios --non-interactive",
    "build:preview": "npx -y eas-cli build --profile preview --platform android --non-interactive",
    "build:prod:android": "npx -y eas-cli build --profile production --platform android --non-interactive",
    "build:prod:ios": "npx -y eas-cli build --profile production --platform ios --non-interactive",
    "migrate": "node scripts/migrate.js",
    "devtools": "react-devtools"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^3.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/app-check": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-navigation/drawer": "^7.1.1",
    "@sentry/react-native": "~6.10.0",
    "@shopify/flash-list": "1.7.3",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.7.0",
    "date-fns": "^3.6.0",
    "expo": "~52.0.0",
    "expo-av": "~15.0.0",
    "expo-blur": "~14.0.0",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-device": "~7.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.7",
    "expo-image-manipulator": "~13.0.0",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "i18next": "^23.11.0",
    "jest": "~29.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.0",
    "react-i18next": "^14.1.0",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-google-places-autocomplete": "^2.6.4",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-maps": "1.18.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "socket.io-client": "^4.8.3",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "puppeteer": "^25.0.4",
    "puppeteer-core": "^25.0.4",
    "react-devtools": "^7.0.1",
    "typescript": "^5.3.0"
  },
  "private": true
}
